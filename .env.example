# AMS — Firebase environment variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.
# For production, set these in the Vercel project dashboard
# (Settings -> Environment Variables).
#
# All variables must start with VITE_ to be exposed to the Vite client bundle.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Seeder / Admin scripts (NEVER committed; used only by scripts/*.ts) ---
#
# Project id to target. May also be set via --project flag or .firebaserc default.
# GOOGLE_CLOUD_PROJECT=ams-yourproject
#
# Path to a service-account JSON key for real-project seeding.
# The .secrets/ directory and service-account*.json are gitignored.
# GOOGLE_APPLICATION_CREDENTIALS=./.secrets/service-account.json
#
# Set this to seed the local Firebase emulator instead of a real project.
# FIRESTORE_EMULATOR_HOST=localhost:8080
#
# Comma-separated list of allowed OAuth email domains written into settings/auth.
# IMPORTANT: if this is empty (or unset), the beforeCreate Cloud Function FAILS
# CLOSED and blocks ALL sign-ups — nobody can sign in, including the first
# super_admin. Always supply this when seeding a real project.
# SEED_ALLOWED_DOMAINS=yourcompany.example
