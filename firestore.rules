rules_version = '2';

// AMS — Asset Management System
// Deny-by-default Firestore security rules.
// Role is server-trusted: read from /users/{uid}.role via get(), NEVER from
// client-supplied custom claims. audit_logs are IMMUTABLE for everyone.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    // The caller's own users doc. Only call after isSignedIn().
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'super_admin';
    }

    function isAssetAdmin() {
      return isSignedIn() && role() == 'asset_admin';
    }

    function isTechAdmin() {
      return isSignedIn() && role() == 'tech_admin';
    }

    function isAnyAdmin() {
      return isSuperAdmin() || isAssetAdmin() || isTechAdmin();
    }

    // Whenever a `role` field is present in the written data it must be one of the
    // four valid roles. Applies to ALL writers (incl. super) so a garbage/legacy
    // role string (e.g. 'admin') can never be persisted.
    function validRoleIfPresent() {
      return !('role' in request.resource.data)
        || request.resource.data.role in ['super_admin', 'asset_admin', 'tech_admin', 'employee'];
    }

    // ---- /users ----
    // Read: self or super_admin. Create/delete + role/status changes: super_admin only.
    // A signed-in user may update their OWN doc only if role + status are unchanged
    // (prevents self role-escalation).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());

      // Create: super_admin (any shape) OR a self-claim of a no-role record that
      // introduces NO role field. Self-escalation is impossible.
      allow create: if validRoleIfPresent() && (
          isSuperAdmin()
          || (
            isSignedIn()
            && request.auth.uid == uid
            && !('role' in request.resource.data)
            && request.resource.data.status == 'no-role'
          )
        );

      // Update: super_admin (any shape) OR a self-update that changes NO role
      // field and keeps status unchanged (self can never grant/raise a role).
      allow update: if validRoleIfPresent() && (
          isSuperAdmin()
          || (
            isSignedIn()
            && request.auth.uid == uid
            && !('role' in request.resource.data.diff(resource.data).affectedKeys())
            && request.resource.data.status == resource.data.status
          )
        );

      allow delete: if isSuperAdmin();
    }

    // ---- /assets ----
    // Read: any admin, OR the employee who has the asset currently assigned to them.
    //   assignment.employeeId is null-guarded: if assignment is null (warehouse) or
    //   employeeId is absent, the condition short-circuits to false (fail-closed).
    // Write: super | asset_admin (full write — create, update, delete).
    // Update (tech_admin, constrained): tech_admin may ONLY flip the repair-workflow
    //   statusId. The write must touch nothing beyond statusId + the two bookkeeping
    //   fields (updatedAt, updatedBy) and the new statusId must be one of the three
    //   repair-workflow values. Assignment, branchId, categoryId, invCode, serial,
    //   etc. are untouchable by tech_admin.
    match /assets/{id} {
      allow read: if isAnyAdmin()
        || (
          isSignedIn()
          && resource.data.assignment != null
          && resource.data.assignment.employeeId != null
          && resource.data.assignment.employeeId == request.auth.uid
        );
      allow write: if isSuperAdmin() || isAssetAdmin();
      allow update: if isTechAdmin()
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['statusId', 'upgradeCurrent', 'updatedAt', 'updatedBy'])
        && request.resource.data.statusId in ['st_repair', 'st_assigned', 'st_warehouse'];

      // Upgrade events: append-only business trail. tech_admin and super_admin only
      // (tech attributes / component upgrades are tech_admin per the role matrix).
      match /upgrades/{upgradeId} {
        allow read: if isSignedIn();
        allow create: if isSuperAdmin() || isTechAdmin();
        allow update, delete: if false;
      }
    }
    // ---- /licenses — workstation/employee licenses ----
    // Read: any admin (device-detail license listing). Write: super | tech_admin
    //   (tech_admin manages licenses per the role matrix). NO employee read.
    // Secrets sub-collection: gated to super_admin OR tech_admin (the two roles
    //   that can manage licenses). Raw keys are written/read directly via the
    //   client SDK; masking is enforced in app code (sanitizeLicenseAuditPayload)
    //   before audit_logs entries are written. asset_admin, employee, and
    //   unauthenticated callers are denied.
    match /licenses/{id} {
      allow read: if isAnyAdmin();
      // A raw `key` field must NEVER live on the license doc — keys belong in the
      // secrets sub-collection only. Reject any doc write carrying `key`,
      // so even a privileged admin client cannot bypass the masking architecture.
      allow write: if (isSuperAdmin() || isTechAdmin())
        && !('key' in request.resource.data);
      match /secrets/{s} {
        allow read, write: if isSuperAdmin() || isTechAdmin();
      }
    }

    // ---- /subscriptions — seat-based SaaS subscriptions ----
    // Read: super_admin OR tech_admin only. The Licenses route is gated to
    //   these two roles; subscription assignee lists are employee PII that
    //   asset_admin does not need to access.
    // Write (create/update): super_admin OR tech_admin. Shape guard requires
    //   assignedEmployeeIds to be a list — defense-in-depth against a malformed
    //   privileged client corrupting the field.
    // Delete: forbidden for all principals.
    match /subscriptions/{id} {
      allow read: if isSuperAdmin() || isTechAdmin();
      allow create, update: if (isSuperAdmin() || isTechAdmin())
        && request.resource.data.assignedEmployeeIds is list;
      allow delete: if false;
    }

    // ---- /server_licenses — global/server/company-wide licenses ----
    // Super-admin WRITE only. Read: any admin.
    // Secrets sub-collection: super_admin only (server licenses are more sensitive
    //   than workstation licenses; tech_admin cannot manage server licenses, so
    //   they cannot access their secrets either).
    match /server_licenses/{id} {
      allow read: if isAnyAdmin();
      // Same key-field guard as /licenses: raw keys live only in secrets/*.
      allow write: if isSuperAdmin()
        && !('key' in request.resource.data);
      match /secrets/{s} {
        allow read, write: if isSuperAdmin();
      }
    }

    match /branches/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAssetAdmin();
    }
    // ---- /employees ----
    // Read: any admin, OR the employee reading their OWN doc (self-service profile).
    //   An employee must NOT read other employees' PII.
    // Create/Update: super | asset_admin (role matrix). Doc id is the person's uid.
    //   email must be a non-empty string (basic shape guard; uniqueness is repo-enforced).
    // Delete: forbidden — employees are soft-deleted via status:'terminated'.
    match /employees/{id} {
      allow read: if isAnyAdmin() || (isSignedIn() && request.auth.uid == id);
      allow create, update: if (isSuperAdmin() || isAssetAdmin())
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0;
      allow delete: if false;
    }

    // ---- Reference catalogs: read any signed-in, write super only ----
    match /asset_statuses/{id} {
      allow read: if isSignedIn();
      // create: super only; new docs must be non-system (clients cannot mint system statuses)
      allow create: if isSuperAdmin()
        && (!('isSystem' in request.resource.data) || request.resource.data.isSystem == false);
      // update: super only; isSystem is immutable for all docs (blocks both promotion and
      // demotion); a system doc also freezes isFinal.
      // The clamp `(req.isSystem==true)==(res.isSystem==true)` handles absent isSystem
      // correctly: absent resolves to null, null==true is false, so a doc without isSystem
      // can only be updated if the write keeps it not-true (absent/false stays absent/false).
      allow update: if isSuperAdmin()
        && (
          (request.resource.data.isSystem == true) == (resource.data.isSystem == true)
        )
        && (
          resource.data.isSystem != true
          || request.resource.data.isFinal == resource.data.isFinal
        );
      // delete: super only AND never a system doc
      allow delete: if isSuperAdmin() && resource.data.isSystem != true;
    }
    match /categories/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    // Departments are reference/catalog data (§5): super_admin only may mutate.
    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ---- /assignments ----
    // Read: any admin, OR the employee whose assignedToEmployeeId matches their uid.
    //   Branch-mode assignments have assignedToEmployeeId == null; null != uid is false
    //   (fail-closed) and does not throw — safe without an extra null guard.
    // Create: super | asset_admin. Update: super | asset_admin but ONLY
    //   endedAt / transferComment may change. Never deletable.
    match /assignments/{id} {
      allow read: if isAnyAdmin()
        || (
          isSignedIn()
          && resource.data.assignedToEmployeeId == request.auth.uid
        );
      allow create: if isSuperAdmin() || isAssetAdmin();
      allow update: if (isSuperAdmin() || isAssetAdmin())
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['endedAt', 'transferComment']);
      allow delete: if false;
    }

    // ---- /audit_logs — IMMUTABLE ----
    // Reads scoped by role. Creates allowed for any signed-in user (writes happen
    // inside withAudit transactions in app code; tightened in a later plan).
    // UPDATE and DELETE are forbidden for EVERYONE, including super_admin. This is
    // the hard security invariant of the system.
    match /audit_logs/{id} {
      allow read: if isAnyAdmin()
        || (
          isSignedIn()
          && resource.data.entityType == 'assignment'
          && resource.data.after != null
          && resource.data.after.assignedToEmployeeId == request.auth.uid
        );
      // create: server-trusted actor + time, required/allowed key sets, and shape guards
      allow create: if isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorRole == role()
        && request.resource.data.at == request.time
        && request.resource.data.entityType is string
        && request.resource.data.entityType.size() > 0
        && request.resource.data.action is string
        && request.resource.data.action.size() > 0
        && (!('before' in request.resource.data)
            || request.resource.data.before == null
            || request.resource.data.before is map)
        && (!('after' in request.resource.data)
            || request.resource.data.after == null
            || request.resource.data.after is map)
        && (!('comment' in request.resource.data)
            || request.resource.data.comment == null
            || request.resource.data.comment is string)
        && request.resource.data.keys().hasAll(
             ['entityType', 'entityId', 'action', 'actorUid', 'actorRole', 'at'])
        && request.resource.data.keys().hasOnly(
             ['entityType', 'entityId', 'action', 'actorUid', 'actorRole',
              'before', 'after', 'comment', 'at']);
      allow update, delete: if false;
    }

    // ---- /mail — Trigger Email queue. Write-only for admins; never client-readable. ----
    match /mail/{id} {
      allow create: if isSuperAdmin() || isAssetAdmin();
      allow read, update, delete: if false;
    }

    // ---- /settings/auth — OAuth allowed-domain doc (super only) ----
    // Read+write super_admin only. allowedEmailDomains, when present, must be a list
    // (rules can't deep-validate each element; the repo + beforeCreate enforce that).
    // beforeCreate reads this via Admin SDK and bypasses rules.
    match /settings/auth {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin()
        && (!('allowedEmailDomains' in request.resource.data)
            || request.resource.data.allowedEmailDomains is list);
    }

    // ---- /settings/{doc} — any other settings doc, super only ----
    // The `doc != 'auth'` guard on write ensures the more-specific /settings/auth block
    // is the SOLE write path for that document; the list-guard above cannot be bypassed
    // by the wildcard match's looser allow write condition.
    match /settings/{doc} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin() && doc != 'auth';
    }

    // ---- /parts — SKU catalog ----
    // Read + create + update: three admin roles. No client delete (MVP boundary —
    // deleteGpu is routed through a Cloud Function in a post-MVP plan).
    // Shape guards:
    //   · category must be one of the 7 defined PartCategory values.
    //   · name must be a non-empty string.
    //   · numeric snapshot fields (onHand, broken, lowStockThreshold) must be numbers.
    //   · attribution: createdBy/updatedBy must equal the caller's uid.
    //   · allowed keys whitelist (optional fields: variantId, variantLabel, ddr).
    match /parts/{id} {
      allow read: if isSignedIn() && role() in ['super_admin', 'asset_admin', 'tech_admin'];

      allow create: if isSignedIn()
        && role() in ['super_admin', 'asset_admin', 'tech_admin']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.category in ['psu', 'cooler', 'ssd', 'hdd', 'nvme', 'ram', 'gpu']
        && request.resource.data.onHand is number
        && request.resource.data.broken is number
        && request.resource.data.lowStockThreshold is number
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
             'name', 'category', 'unit', 'onHand', 'broken', 'lowStockThreshold',
             'variantId', 'variantLabel', 'ddr',
             'createdAt', 'updatedAt', 'createdBy', 'updatedBy']);

      allow update: if isSignedIn()
        && role() in ['super_admin', 'asset_admin', 'tech_admin']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.category in ['psu', 'cooler', 'ssd', 'hdd', 'nvme', 'ram', 'gpu']
        && request.resource.data.onHand is number
        && request.resource.data.broken is number
        && request.resource.data.lowStockThreshold is number
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
             'name', 'category', 'unit', 'onHand', 'broken', 'lowStockThreshold',
             'variantId', 'variantLabel', 'ddr',
             'createdAt', 'updatedAt', 'createdBy', 'updatedBy']);

      allow delete: if false;
    }

    // ---- /part_movements — append-only stock journal ----
    // Immutable like audit_logs: update and delete forbidden for ALL principals.
    // Create allowed for the three admin roles, with server-trusted attribution guards
    // (mirroring audit_logs create) so forged actorUid/actorRole/at can never persist:
    //   · actorUid   must equal the caller's uid.
    //   · actorRole  must equal the caller's server-verified role (read from /users/{uid}).
    //   · at         must equal request.time (server timestamp — rules compare timestamps).
    //   · type       must be one of the four defined MovementType values.
    //   · keys()     are whitelisted; optional fields (assetId, assetInvCode, note, reason,
    //                kindId, kindLabel) may be absent but are the ONLY extras allowed.
    match /part_movements/{id} {
      allow read: if isSignedIn() && role() in ['super_admin', 'asset_admin', 'tech_admin'];

      allow create: if isSignedIn()
        && role() in ['super_admin', 'asset_admin', 'tech_admin']
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorRole == role()
        && request.resource.data.at == request.time
        && request.resource.data.type in ['receive', 'install', 'uninstall', 'service']
        && request.resource.data.keys().hasOnly([
             'type', 'skuId', 'qty', 'broken', 'assetId', 'assetInvCode',
             'serviceReplace', 'note', 'reason', 'kindId', 'kindLabel',
             'actorUid', 'actorRole', 'at']);

      allow update, delete: if false;
    }

    // ---- Catch-all: deny everything not matched above ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
