{
  "name": "ams",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --project demo-ams --only firestore,storage \"vitest run tests/rules\"",
    "typecheck": "tsc --noEmit",
    "build:functions": "cd functions && npm ci && npm run build",
    "deploy:rules": "npx firebase deploy --only firestore:rules,storage:rules,firestore:indexes",
    "deploy:functions": "npx firebase deploy --only functions",
    "deploy:backend": "npm run deploy:rules && npm run deploy:functions",
    "deploy:indexes": "npx firebase deploy --only firestore:indexes",
    "deploy:all": "npx firebase deploy --only firestore:rules,storage:rules,firestore:indexes,functions",
    "emulators": "npx firebase emulators:start",
    "seed": "tsx scripts/seed.ts",
    "seed:emulator": "cross-env FIRESTORE_EMULATOR_HOST=localhost:8080 GOOGLE_CLOUD_PROJECT=demo-ams tsx scripts/seed.ts",
    "grant:super-admin": "tsx scripts/grant-super-admin.ts",
    "backfill:category-caps": "tsx scripts/backfill-category-caps.ts",
    "migrate:category-groups": "tsx scripts/migrate-category-groups.ts",
    "clear:assets": "tsx scripts/clearAssets.ts",
    "delete:asset": "tsx scripts/deleteAsset.ts",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "firebase": "^12.15.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^13.35.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  }
}
